# KubeCost-Gym Environment Variables
# Copy this file to .env and fill in the required values

# REQUIRED: API key for the LLM endpoint
# This is NOT a HuggingFace user token - it's the API key for your LLM service
# For HuggingFace's router: Get from https://huggingface.co/settings/tokens (create a token with read access)
HF_TOKEN=your-api-key-here

# OPTIONAL: LLM endpoint URL (defaults to HuggingFace's router)
# Example for OpenAI: https://api.openai.com/v1
# Example for HuggingFace: https://router.huggingface.co/v1
# Example for local/self-hosted: http://localhost:8000/v1
API_BASE_URL=https://router.huggingface.co/v1

# OPTIONAL: LLM model identifier (defaults to Mistral-7B via HuggingFace)
# Example for OpenAI: gpt-4 or gpt-4-turbo-preview
# Example for HuggingFace: mistralai/Mistral-7B-Instruct-v0.2:featherless-ai
# Example for local: custom-model
MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2:featherless-ai

# OPTIONAL: Server configuration (for local testing)
# Change this only if you're running locally and need a different port
# HuggingFace Spaces will override this to 7860
PORT=7860
SERVER_NAME=0.0.0.0
