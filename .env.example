# KubeCost-Gym Environment Configuration Examples
# Copy this to .env and uncomment/modify the section you need

# ============================================
# Option 1: OpenAI GPT-4 (Recommended)
# ============================================
# HF_TOKEN=sk-your-openai-api-key
# MODEL_NAME=gpt-4
# API_BASE_URL=https://api.openai.com/v1

# ============================================
# Option 2: OpenAI GPT-3.5 Turbo (Cheaper)
# ============================================
# HF_TOKEN=sk-your-openai-api-key
# MODEL_NAME=gpt-3.5-turbo
# API_BASE_URL=https://api.openai.com/v1

# ============================================
# Option 3: HuggingFace Inference API
# ============================================
# HF_TOKEN=hf_your-huggingface-token
# MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2
# API_BASE_URL=https://api-inference.huggingface.co/models

# ============================================
# Option 4: NVIDIA API Catalog
# ============================================
# HF_TOKEN=nvapi-your-nvidia-api-key
# MODEL_NAME=openai/gpt-oss-120b
# API_BASE_URL=https://integrate.api.nvidia.com/v1

# ============================================
# Option 5: Local LLM (Ollama, LM Studio, etc.)
# ============================================
# HF_TOKEN=dummy-token
# MODEL_NAME=llama2
# API_BASE_URL=http://localhost:11434/v1

# ============================================
# Reward Shaping & Environment Parameters
# (Optional - Defaults are shown below)
# ============================================
# ENV_UPTIME_REWARD=10.0
# ENV_COST_PENALTY_RATE=5.0
# ENV_COST_PENALTY_CAP=5.0
# ENV_RAMP_PENALTY_RATE=5.0
# ENV_SLA_BREACH_PENALTY=20.0
# ENV_PROACTIVE_BONUS=0.5

# ============================================
# Deployment & Logging Configuration
# ============================================
# REPO_ID=username/k8s-cost-optimizer
# HF_USER_TOKEN=hf_your-read-only-access-token
